# 文本生成API（主）
TEXT_API_PROVIDER=openai
TEXT_API_KEY=
TEXT_API_BASE_URL=https://api.openai.com/v1
TEXT_MODEL=gpt-4o-mini
TEXT_TEMPERATURE=0.7
TEXT_MAX_TOKENS=4096

# 文本生成API（备选）
TEXT_FALLBACK_PROVIDER=
TEXT_FALLBACK_API_KEY=
TEXT_FALLBACK_API_BASE_URL=
TEXT_FALLBACK_MODEL=

# 图片生成API
IMAGE_API_PROVIDER=openai
IMAGE_API_KEY=
IMAGE_API_BASE_URL=https://api.openai.com/v1
IMAGE_MODEL=dall-e-3
IMAGE_SIZE=1024x1024

# 应用配置
DEBUG=true
